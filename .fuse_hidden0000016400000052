<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Foreign Rights – Titania Blesh</title>
<meta name="description" content="Foreign rights, subsidiary rights, and submission information for the works of Italian SFF author Titania Blesh – Trofeo Cittadella 2021 finalist, Trofeo Cassiopea 2022 winner. Piratesse del Mediterraneo trilogy English rights worldwide available.">
<link rel="icon" type="image/png" href="assets/images/favicon.png">
<link rel="apple-touch-icon" href="assets/images/favicon.png">
<link rel="stylesheet" href="assets/fonts/fonts.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400;1,700&display=swap">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ─── PALETTES (mirrors index.html) ───────────────── */
:root {
  --bg:         #f5ede0;
  --bg-2:       #ece2cf;
  --bg-3:       #ddd0b6;
  --rule:       #ddd0b6;
  --rule-soft:  rgba(31,24,21,0.08);

  --txt:        #1f1815;
  --txt-mid:    #4a3d33;
  --txt-lt:     #8a7c6c;

  --accent:     #7a2e2e;
  --accent-dk:  #5b2020;
  --accent-lt:  #a14545;

  --gold:       #b88a3a;
  --gold-lt:    #d8b87a;

  --display:    'Lato', 'Nunito', system-ui, sans-serif;
  --body:       'Nunito', system-ui, -apple-system, sans-serif;
}

.volcanic {
  --bg:        #0d0908;
  --bg-2:      #14110f;
  --bg-3:      #1d1814;
  --rule:      rgba(240,230,212,0.16);
  --rule-soft: rgba(240,230,212,0.07);
  --txt:       #f0e6d4;
  --txt-mid:   #c5b89d;
  --txt-lt:    #847964;
  --accent:    #e85d2c;
  --accent-dk: #b8431b;
  --accent-lt: #f08855;
  --gold:      #d8a64a;
  --gold-lt:   #ebc77b;
}

html { scroll-behavior: smooth; scroll-padding-top: 6rem; }

body {
  background: var(--bg);
  color: var(--txt);
  font-family: var(--body);
  font-size: 17px;
  line-height: 1.7;
  overflow-x: hidden;
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; }

/* ─── NAV / MASTHEAD ─────────────────────────────── */
nav.masthead {
  position: sticky; top: 0; z-index: 100;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 1.5rem;
  padding: 1.4rem 3rem 1.2rem;
  background-color: #0d0908;
  background-image: linear-gradient(to right,
    rgba(240,230,212,0)    0%,
    rgba(240,230,212,0.15) 8%,
    rgba(240,230,212,0.55) 16%,
    rgba(240,230,212,0.92) 24%,
    rgba(240,230,212,1)    32%,
    rgba(240,230,212,1)    68%,
    rgba(240,230,212,0.92) 76%,
    rgba(240,230,212,0.55) 84%,
    rgba(240,230,212,0.15) 92%,
    rgba(240,230,212,0)   100%);
  background-position: bottom;
  background-size: 100% 2px;
  background-repeat: no-repeat;
}
.brand { display: flex; align-items: center; gap: 0.7rem; text-decoration: none; }
.brand-logo {
  display: inline-flex; align-items: center; justify-content: center;
  width: 44px; height: 44px; flex-shrink: 0;
}
.brand-logo img { height: 32px; width: auto; }
.brand-text {
  font-family: 'Lato', var(--body), system-ui, sans-serif;
  text-transform: uppercase;
  font-size: 1rem; color: #f0e6d4;
}
.nav-links {
  display: flex; gap: 2.2rem; list-style: none; align-items: center;
  justify-content: center; grid-column: 2;
}
.nav-links a {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: #c5b89d; text-decoration: none;
  padding-bottom: 2px; border-bottom: 1.5px solid transparent;
  transition: color 0.2s, border-color 0.2s;
}
.nav-links a:hover { color: #e85d2c; border-bottom-color: #e85d2c; }
.nav-links a.active { color: #e85d2c; border-bottom-color: #e85d2c; }
.nav-cta {
  grid-column: 3;
  font-family: var(--body); font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  text-decoration: none;
  background-color: #e85d2c; color: #0d0908;
  border: 1.5px solid #e85d2c;
  padding: 0.55rem 1.1rem;
  transition: background 0.2s, color 0.2s, transform 0.15s;
  white-space: nowrap;
}
.nav-cta:hover {
  background-color: transparent; color: #e85d2c;
  transform: translateY(-1px);
}
.nav-burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
.nav-burger span { display: block; width: 22px; height: 2px; background: #f0e6d4; border-radius: 2px; transition: all 0.3s; }

/* ─── PAGE WRAPPER ───────────────────────────────── */
main { padding: 0; }

/* ─── HEADER ─────────────────────────────────────── */
.rights-header {
  background: var(--bg);
  padding: 5rem 3rem 3rem;
  border-bottom: 1px solid var(--rule);
  text-align: center;
}
.rights-header .eyebrow {
  font-family: var(--body); font-size: 0.78rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 1.2rem;
}
.rights-header h1 {
  font-family: var(--display); font-weight: 700;
  font-size: clamp(2.2rem, 4.5vw, 3.4rem);
  line-height: 1.1; letter-spacing: -0.01em;
  color: var(--txt); margin-bottom: 0.6rem;
}
.rights-header h1 .accent { color: var(--accent); }
.rights-header .author-line {
  font-family: var(--display); font-size: 1.1rem; font-weight: 400;
  font-style: italic; color: var(--txt-mid); margin-bottom: 1.6rem;
}
.rights-header .deck {
  max-width: 760px; margin: 0 auto;
  font-size: 1.04rem; color: var(--txt-mid); line-height: 1.7;
}
.rights-header .ornament {
  display: flex; align-items: center; justify-content: center;
  gap: 0.8rem; margin: 1.6rem auto 1.6rem;
  color: var(--gold);
}
.rights-header .ornament .line {
  height: 1px; width: 70px; background: var(--rule);
}
.rights-header .ornament .glyph {
  font-size: 0.9rem; letter-spacing: 0.4em; color: var(--gold);
}

/* ─── SECTION SHELL ──────────────────────────────── */
.r-section {
  padding: 4.5rem 3rem;
  border-bottom: 1px solid var(--rule);
}
.r-section.alt { background: var(--bg-2); }
.r-section.dark { background: var(--bg); }
.r-inner { max-width: 1100px; margin: 0 auto; }
.r-section .sec-eyebrow {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 0.9rem;
}
.r-section h2 {
  font-family: var(--display); font-weight: 700;
  font-size: clamp(1.7rem, 3vw, 2.3rem);
  line-height: 1.2; color: var(--txt);
  margin-bottom: 1.2rem;
}
.r-section h2 .accent { color: var(--accent); }
.r-section .sec-deck {
  max-width: 720px; font-size: 1rem;
  color: var(--txt-mid); margin-bottom: 2.4rem;
}

/* ─── LEAD: PIRATESSE TRILOGY ────────────────────── */
.lead-pitch {
  background: var(--bg);
  border: 1px solid var(--rule);
  padding: 2.5rem 2.6rem;
  margin-bottom: 2rem;
  position: relative;
}
.lead-pitch::before {
  content: '✦';
  position: absolute; top: -0.7rem; left: 2rem;
  background: var(--bg-2);
  color: var(--gold); font-size: 0.9rem;
  padding: 0 0.55rem;
  letter-spacing: 0.4em;
}
.lead-pitch .pitch-line {
  font-family: var(--display);
  font-size: clamp(1.15rem, 2vw, 1.4rem);
  line-height: 1.5; color: var(--txt);
  font-style: italic;
  margin-bottom: 1.4rem;
}
.lead-pitch .pitch-line strong {
  font-style: normal; color: var(--accent);
  font-weight: 700;
}
.lead-pitch .premise {
  font-size: 1rem; color: var(--txt-mid);
  line-height: 1.75; margin-bottom: 1.4rem;
}

/* Specs & rights status grid */
.lead-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.6rem;
  margin-top: 2rem;
}
.lead-block {
  background: var(--bg-2);
  border: 1px solid var(--rule);
  padding: 1.4rem 1.6rem;
}
.lead-block .label {
  font-family: var(--body); font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 0.8rem;
}
.lead-block dl {
  display: grid;
  grid-template-columns: max-content 1fr;
  column-gap: 1.2rem; row-gap: 0.55rem;
  font-size: 0.95rem;
}
.lead-block dt {
  color: var(--txt-lt); font-size: 0.82rem;
  text-transform: uppercase; letter-spacing: 0.08em;
  font-weight: 700; padding-top: 0.15rem;
}
.lead-block dd { color: var(--txt); }
.lead-block dd strong { color: var(--accent); font-weight: 700; }

/* Rights status panel – emphasized */
.rights-panel {
  background: var(--bg);
  border: 1.5px solid var(--accent);
  padding: 1.6rem 1.8rem;
  margin: 2rem 0;
}
.rights-panel .label {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 1rem;
}
.rights-panel-grid {
  display: grid;
  grid-template-columns: max-content 1fr;
  column-gap: 1.4rem; row-gap: 0.55rem;
  font-size: 0.97rem;
}
.rights-panel-grid dt {
  color: var(--txt); font-weight: 700;
}
.rights-panel-grid dd { color: var(--txt-mid); }
.rights-panel-grid .available {
  color: #1d6e2e; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  font-size: 0.85rem;
}
.rights-panel-grid .sold {
  color: var(--txt-mid); font-style: italic;
}

/* Comps */
.comps {
  margin-top: 2rem;
}
.comps h3 {
  font-family: var(--body); font-size: 0.78rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 1.2rem;
}
.comps-list {
  list-style: none; padding: 0;
  display: grid; gap: 0.9rem;
}
.comps-list li {
  display: grid;
  grid-template-columns: max-content 1fr;
  gap: 1rem;
  padding: 0.8rem 0;
  border-top: 1px dashed var(--rule);
  font-size: 0.96rem;
}
.comps-list li:first-child { border-top: none; padding-top: 0.2rem; }
.comps-list .comp-title {
  color: var(--txt); font-weight: 700; font-style: italic;
}
.comps-list .comp-title em {
  font-style: italic; color: var(--accent); font-weight: 700;
}
.comps-list .comp-author {
  display: block; color: var(--txt-lt);
  font-size: 0.82rem; font-weight: 400;
  font-style: normal; margin-top: 0.15rem;
}
.comps-list .comp-rationale {
  color: var(--txt-mid); line-height: 1.65;
}

/* CTA row for downloads */
.lead-ctas {
  display: flex; flex-wrap: wrap; gap: 0.8rem;
  margin-top: 2.2rem;
}
.btn {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  text-decoration: none;
  padding: 0.65rem 1.2rem;
  transition: background 0.2s, color 0.2s, transform 0.15s;
  white-space: nowrap;
  border: 1.5px solid var(--accent);
}
.btn-fill { background: var(--accent); color: var(--bg); }
.btn-fill:hover { background: transparent; color: var(--accent); transform: translateY(-1px); }
.btn-outline { background: transparent; color: var(--accent); }
.btn-outline:hover { background: var(--accent); color: var(--bg); transform: translateY(-1px); }
.btn-disabled {
  background: var(--bg-2); color: var(--txt-lt);
  border-color: var(--rule); cursor: not-allowed;
  pointer-events: none;
}
.btn-note {
  font-family: var(--body); font-style: italic;
  font-size: 0.82rem; color: var(--txt-lt);
  text-transform: none; letter-spacing: 0;
}

/* ─── BACKLIST CARDS ─────────────────────────────── */
.work-card {
  background: var(--bg);
  border: 1px solid var(--rule);
  padding: 1.8rem 2rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.2rem;
  margin-bottom: 1.4rem;
}
.work-card-head {
  display: flex; flex-wrap: wrap; align-items: baseline;
  gap: 0.8rem; row-gap: 0.4rem;
  border-bottom: 1px dashed var(--rule);
  padding-bottom: 0.9rem;
}
.work-card-title {
  font-family: var(--display);
  font-size: 1.4rem; font-weight: 700;
  font-style: italic; color: var(--txt);
}
.work-card-genre {
  font-family: var(--body); font-size: 0.78rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--accent);
}
.work-card-spec {
  font-family: var(--body); font-size: 0.85rem;
  color: var(--txt-lt); margin-left: auto;
}
.work-card-logline {
  font-size: 0.98rem; color: var(--txt-mid);
  line-height: 1.7;
}
.work-card-meta {
  display: grid;
  grid-template-columns: max-content 1fr;
  column-gap: 1.2rem; row-gap: 0.4rem;
  font-size: 0.92rem;
  margin-top: 0.4rem;
}
.work-card-meta dt {
  color: var(--txt-lt); font-size: 0.78rem;
  text-transform: uppercase; letter-spacing: 0.08em;
  font-weight: 700; padding-top: 0.18rem;
}
.work-card-meta dd { color: var(--txt); }
.work-card-meta dd .available {
  color: #1d6e2e; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  font-size: 0.82rem;
}
.work-card-meta dd .sold {
  color: var(--txt-mid); font-style: italic;
}
.work-card-recognition {
  font-family: var(--body); font-size: 0.88rem;
  color: var(--accent); font-weight: 700;
  border-left: 2px solid var(--gold);
  padding-left: 0.9rem;
}

/* ─── MANUSCRIPTS GRID ───────────────────────────── */
.ms-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.4rem;
}
.ms-card {
  background: var(--bg);
  border: 1px solid var(--rule);
  padding: 1.6rem 1.7rem;
  display: flex; flex-direction: column;
  gap: 0.9rem;
}
.ms-card-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 0.8rem;
  border-bottom: 1px dashed var(--rule);
  padding-bottom: 0.9rem;
}
.ms-card-title {
  font-family: var(--display);
  font-size: 1.25rem; font-weight: 700;
  font-style: italic; color: var(--txt);
}
.ms-card-genre {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--accent); margin-top: 0.25rem;
}
.ms-card-spice {
  font-size: 0.82rem; white-space: nowrap;
  letter-spacing: 0.08em;
  color: var(--txt-lt);
}
.ms-card-spice .pep { color: var(--accent); }
.ms-card-logline {
  font-size: 0.96rem; color: var(--txt-mid);
  line-height: 1.7; flex-grow: 1;
}
.ms-card-meta {
  display: grid;
  grid-template-columns: max-content 1fr;
  column-gap: 1rem; row-gap: 0.35rem;
  font-size: 0.86rem;
}
.ms-card-meta dt {
  color: var(--txt-lt); font-size: 0.74rem;
  text-transform: uppercase; letter-spacing: 0.08em;
  font-weight: 700;
}
.ms-card-meta dd { color: var(--txt); }
.ms-card-meta dd .available {
  color: #1d6e2e; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  font-size: 0.78rem;
}
.placeholder {
  color: var(--txt-lt); font-style: italic;
  background: linear-gradient(transparent 60%, rgba(184,138,58,0.18) 60%);
  padding: 0 0.15em;
}

/* ─── RECOGNITION STRIP ──────────────────────────── */
.awards-list {
  list-style: none; padding: 0;
  display: grid; gap: 1rem;
}
.awards-list li {
  display: grid;
  grid-template-columns: max-content 1fr;
  gap: 1.4rem;
  padding: 1.2rem 1.4rem;
  background: var(--bg);
  border-left: 3px solid var(--gold);
  border-top: 1px solid var(--rule);
  border-right: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
}
.awards-list .award-year {
  font-family: var(--display);
  font-size: 1.6rem; font-weight: 700;
  color: var(--accent); line-height: 1;
  align-self: center;
}
.awards-list .award-body { color: var(--txt); }
.awards-list .award-name {
  font-family: var(--display);
  font-size: 1.1rem; font-weight: 700;
  color: var(--txt); margin-bottom: 0.2rem;
}
.awards-list .award-detail {
  font-size: 0.92rem; color: var(--txt-mid);
}
.awards-list .award-detail em {
  font-style: italic; color: var(--accent); font-weight: 700;
}

/* ─── PRESS QUOTES ───────────────────────────────── */
.press-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.4rem;
}
.press-card {
  background: var(--bg);
  border: 1px solid var(--rule);
  padding: 1.5rem 1.7rem;
}
.press-card blockquote {
  font-family: var(--display);
  font-size: 1.02rem; font-style: italic;
  color: var(--txt); line-height: 1.6;
  margin-bottom: 1rem;
}
.press-card .source {
  font-family: var(--body); font-size: 0.78rem;
  font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--accent);
  display: block;
}
.press-card .source-meta {
  font-family: var(--body); font-size: 0.78rem;
  color: var(--txt-lt); margin-top: 0.2rem;
  font-style: italic;
}

/* ─── AUTHOR ─────────────────────────────────────── */
.author-block {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 2.4rem;
  align-items: start;
}
.author-photo img {
  border: 1px solid var(--bg-3);
  filter: sepia(8%) saturate(0.92);
}
.author-bio p {
  color: var(--txt-mid); font-size: 1rem;
  line-height: 1.8; margin-bottom: 0.9rem;
}
.author-bio p:last-child { margin-bottom: 0; }
.author-bio strong {
  color: var(--txt); font-weight: 700;
}
.author-bio em {
  font-style: italic; color: var(--accent);
}

/* ─── CONTACT (volcanic) ─────────────────────────── */
.contact-section {
  padding: 5rem 3rem;
  text-align: center;
}
.contact-section .sec-eyebrow {
  color: var(--gold); margin-bottom: 1rem;
}
.contact-section h2 {
  font-family: var(--display); font-weight: 700;
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  color: var(--txt); margin-bottom: 1rem;
}
.contact-section h2 .accent { color: var(--accent); }
.contact-section .sec-deck {
  max-width: 660px; margin: 0 auto 2rem;
  color: var(--txt-mid); font-size: 1.02rem;
}
.contact-card {
  max-width: 720px; margin: 0 auto;
  background: var(--bg-2);
  border: 1px solid var(--rule);
  padding: 2rem 2.4rem;
}
.contact-card .label {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent-lt); margin-bottom: 0.8rem;
}
.contact-card .email {
  font-family: var(--display);
  font-size: 1.5rem; font-weight: 700;
  color: var(--txt); text-decoration: none;
  display: inline-block; margin-bottom: 1.2rem;
  border-bottom: 2px solid var(--accent);
}
.contact-card .email:hover { color: var(--accent-lt); }
.contact-card .note {
  color: var(--txt-mid); font-size: 0.95rem; line-height: 1.7;
  font-style: italic;
}
.contact-card .note strong {
  color: var(--txt); font-style: normal; font-weight: 700;
}

/* ─── DOWNLOADS ──────────────────────────────────── */
.downloads {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1rem;
  margin-top: 2.4rem;
}
.dl-card {
  background: var(--bg);
  border: 1px solid var(--rule);
  padding: 1.2rem 1.4rem;
  display: flex; flex-direction: column; gap: 0.5rem;
  text-decoration: none;
}
.dl-card .dl-label {
  font-family: var(--body); font-size: 0.74rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--accent);
}
.dl-card .dl-title {
  font-family: var(--display); font-weight: 700;
  font-size: 1.05rem; color: var(--txt);
}
.dl-card .dl-meta {
  font-size: 0.85rem; color: var(--txt-lt);
}
.dl-card.coming {
  background: var(--bg-2);
}
